@using MySql.Data.MySqlClient;
@page "/4"

<div class="page4-wrap">
    <div class="page4-header">
        <div class="page4-badge">USERS</div>
        <h1 class="page4-title">Users Table</h1>
        <p class="page4-sub">Live data from MySQL</p>
    </div>

    <div class="page4-card">
        <table class="page4-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>NAME</th>
                    <th>EMAIL</th>
                </tr>
            </thead>
            <tbody>
                @while (reader.Read())
                {
                    string name = reader["UserName"].ToString();
                    string Email = reader["UserEmail"].ToString();
                    int id = int.Parse(reader["IdUsers"].ToString());
                    <tr>
                        <td>@id</td>
                        <td>@name</td>
                        <td>@Email</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .page4-wrap {
        --bg1: #0b1020;
        --bg2: #120a2a;
        --text: rgba(255,255,255,.92);
        --muted: rgba(255,255,255,.65);
        --border: rgba(255,255,255,.14);
        --shadow: 0 18px 55px rgba(120,80,255,.22);
        --r: 18px;
        min-height: 100vh;
        padding: 48px 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        color: var(--text);
        font-family: ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Arial;
        background: radial-gradient(900px 520px at 20% 15%, rgba(120, 80, 255, .20), transparent 60%), radial-gradient(700px 420px at 85% 25%, rgba(0, 220, 255, .16), transparent 55%), linear-gradient(160deg, var(--bg1), var(--bg2));
    }

    .page4-header {
        width: min(980px, 95vw);
        text-align: center;
        margin-bottom: 6px;
    }

    .page4-badge {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(0,0,0,.22);
        letter-spacing: .24em;
        font-weight: 800;
        font-size: 12px;
        color: rgba(255,255,255,.75);
        box-shadow: 0 10px 25px rgba(0,0,0,.25);
    }

    .page4-title {
        margin: 10px 0 4px;
        font-size: clamp(26px, 3vw, 38px);
        line-height: 1.1;
        letter-spacing: .02em;
        text-shadow: 0 0 22px rgba(120,80,255,.35);
    }

    .page4-sub {
        margin: 0;
        color: var(--muted);
    }

    .page4-card {
        width: min(980px, 95vw);
        border-radius: calc(var(--r) + 6px);
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.05));
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: var(--shadow);
        overflow: hidden;
        position: relative;
    }

        .page4-card::before {
            content: "";
            position: absolute;
            inset: -2px;
            background: radial-gradient(600px 240px at 20% 0%, rgba(0,220,255,.18), transparent 60%), radial-gradient(560px 220px at 80% 0%, rgba(120,80,255,.22), transparent 60%);
            pointer-events: none;
            opacity: .8;
        }

    .page4-table {
        position: relative;
        z-index: 1;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 15px;
    }

        .page4-table thead th {
            text-align: left;
            padding: 14px 16px;
            letter-spacing: .12em;
            font-size: 12px;
            font-weight: 900;
            color: rgba(255,255,255,.78);
            background: rgba(0,0,0,.28);
            border-bottom: 1px solid rgba(255,255,255,.10);
        }

            .page4-table thead th:first-child {
                width: 110px;
            }

        .page4-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            color: rgba(255,255,255,.90);
            overflow-wrap: anywhere;
        }

        .page4-table tbody tr {
            transition: transform 140ms ease, background 140ms ease;
            background: transparent;
        }

            .page4-table tbody tr:nth-child(even) {
                background: rgba(255,255,255,.03);
            }

            .page4-table tbody tr:hover {
                background: rgba(0,220,255,.08);
                transform: translateY(-1px);
            }

        .page4-table tbody td:first-child {
            font-variant-numeric: tabular-nums;
            color: rgba(255,255,255,.82);
        }
</style>
@code
{
    MySqlDataReader reader;
    protected override void OnInitialized()
    {
        MySqlConnection con = new MySqlConnection();
        con.ConnectionString = "server=localhost;user id =root;password=josh17rog;database=gadhw1";
        con.Open();

        MySqlCommand cmd4 = new MySqlCommand();
