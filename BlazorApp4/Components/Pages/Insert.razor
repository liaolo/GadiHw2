@using MySql.Data.MySqlClient;
@page "/3"

<input type="password" @bind="pass" placeholder="Enter you password" />
<input type="text" @bind="email" placeholder="Enter you email" />
<input type="text" @bind="username" placeholder="Enter you username" />
<button @onclick="INSERT">sumbit</button>
<p>@Message</p>

@code
{
    string pass = "";
    string email = "";
    string username = "";
    string Message = "";
    void INSERT()
    {
        MySqlConnection con = new MySqlConnection();
        con.ConnectionString = "server=localhost;user id =root;password=josh17rog;database=gadhw1";
        con.Open();

        string sql = $"INSERT INTO `gadhw1`.`userdatabase` (`UserName`, `UserPassword`, `UserEmail`) VALUES ('{username}', '{pass}', '{email}');";
        MySqlCommand cmd = new MySqlCommand();
        cmd.Connection = con;
        cmd.CommandText = sql;
        int num = cmd.ExecuteNonQuery();
        if (num > 0)
        {
            Message = "Worked";
        }
        else
        {
            Message = "No work";
        }
    }
}

